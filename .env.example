# Plantilla de entorno para desarrollo local.
# No guardes secretos reales aquí ni los subas a Git.
# La app cliente ya no debe usar una Gemini API key pública desde variables `EXPO_PUBLIC_*`.
# En modo desarrollo, si quieres probar BYOK, introduce la key desde la propia app para que quede en SecureStore.

EXPO_PUBLIC_AI_BACKEND_URL=https://europe-west1-your-firebase-project-id.cloudfunctions.net
EXPO_PUBLIC_AI_GENERATE_PLAN_URL=https://generateplan-your-hash-ew.a.run.app
EXPO_PUBLIC_AI_COACH_CHAT_URL=https://coachchat-your-hash-ew.a.run.app
EXPO_PUBLIC_AI_PROACTIVE_COACH_URL=https://proactivecoach-your-hash-ew.a.run.app
